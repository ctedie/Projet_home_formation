# ============================================
# VARIABLES D'ENVIRONNEMENT - BACKEND
# ============================================

# Port du serveur
PORT=3001

# Base de données MySQL
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=projet_recette

# JWT - Secret key (générer une clé longue et complexe)
JWT_SECRET=votre_clé_secrète_très_longue_et_complexe_ici_min_32_caractères

# Environment (development, production)
NODE_ENV=development

# ============================================
# NOTES:
# - NE PAS committer le fichier .env
# - Copier .env.example en .env et compléter
# - Changer JWT_SECRET en production !
# - DB_PASSWORD peut rester vide si utilisateur root sans mdp
# ============================================